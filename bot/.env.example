# Токен Telegram бота от @BotFather
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# URL проекта Supabase
SUPABASE_URL=https://your-project.supabase.co

# Service Role ключ из настроек Supabase (Settings -> API)
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# URL веб-приложения (бэклог), показывается по кнопке "📋 Просмотреть бэклог"
APP_URL=https://your-app.replit.app

# Replit AI интеграция для OpenAI (устанавливается автоматически)
AI_INTEGRATIONS_OPENAI_BASE_URL=https://...
AI_INTEGRATIONS_OPENAI_API_KEY=dummy
